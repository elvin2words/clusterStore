{
  "name": "clusterstore-platform",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "clusterstore-platform",
      "workspaces": [
        "packages/*",
        "services/*"
      ]
    },
    "node_modules/@clusterstore/cluster-ems": {
      "resolved": "services/cluster-ems",
      "link": true
    },
    "node_modules/@clusterstore/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@clusterstore/utilitycore-bridge": {
      "resolved": "services/utilitycore-bridge",
      "link": true
    },
    "packages/contracts": {
      "name": "@clusterstore/contracts",
      "version": "0.1.0"
    },
    "services/cluster-ems": {
      "name": "@clusterstore/cluster-ems",
      "version": "0.1.0"
    },
    "services/utilitycore-bridge": {
      "name": "@clusterstore/utilitycore-bridge",
      "version": "0.1.0"
    }
  }
}
